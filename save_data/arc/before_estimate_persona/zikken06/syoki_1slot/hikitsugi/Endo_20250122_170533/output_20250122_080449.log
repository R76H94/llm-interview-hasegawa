{'現在のキャリア': {'category': 'キャリア', 'value': '看護管理領域'}, '未来像': {'category': 'キャリア', 'value': 'リーダーシップやチームマネジメントのスキルを伸ばし、スタッフの意見をまとめ、円滑に業務を進める力を磨きたい'}, '悩みや不満点': {'category': 'キャリア', 'value': None}, 'リフレッシュ方法': {'category': 'プライベート', 'value': '子供と一緒に手芸を楽しむ'}, '研修の希望': {'category': 'キャリア', 'value': '院内でのリーダーシップ中級編研修'}, '来年のキャリア希望': {'category': 'キャリア', 'value': '継続'}}

