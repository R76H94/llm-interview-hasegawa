{"$defs": {"Slot": {"properties": {"category": {"title": "スロットのカテゴリ", "type": "string"}, "value": {"anyOf": [{"type": "string"}, {"type": "null"}], "default": null, "title": "スロットの値"}}, "required": ["category"], "title": "Slot", "type": "object"}}, "additionalProperties": {"$ref": "#/$defs/Slot"}}
