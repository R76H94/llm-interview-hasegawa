{'タスク管理': '情報なし', '好きな音楽': '情報なし', '性格': '誠実で信頼される性格', '価値観': '患者や家族に真摯に向き合い、安心感を与えることを大切にしている', 'チームワークの具体例': '情報なし', 'オンライン会議における悩みごと': '情報なし', '尊敬する人': '情報なし', '作るのが得意な料理': '情報なし', '副業': '情報なし', '感情のコントロールで気をつけていること': None, '語学学習のポイント': None, '行ってみたい国': None, 'スポーツ観戦': None, '未来像': '助産師の資格を取得し、患者の心身のケアをより深くサポートできる存在になりたい', '飼っているペット': None, '個人の基本的情報': None, 'パソコンを使う頻度': None, 'SNS': None, '服装の好み': None, '使用しているスマートフォンアプリ': None, 'かかりつけの病院': None, '専門スキルの習得': '情報なし', '思い出・エピソード': None, '昨日起きたとても悲しい出来事': None, '好きな言葉・座右の銘': None, '好きなお菓子': None, '通勤時の移動方法': None, '断捨離や片付けのコツ': None, '好きな芸能人': None}

