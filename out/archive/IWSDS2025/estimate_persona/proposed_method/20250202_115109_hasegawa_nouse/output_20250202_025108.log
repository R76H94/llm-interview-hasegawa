  "Target_Slot": { // 1つ以上のスロットから効率的に質問を作成
    "スロット名1": { // スロット名
      "question_priority": 0
      "value": null
    },
    "スロット名2": { // スロット名
      "question_priority": 0
      "value": null
    }
  },
  "Question": "質問発話" // 質問を1つだけ作成
}

