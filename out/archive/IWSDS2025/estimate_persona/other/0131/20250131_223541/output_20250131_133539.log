{"$defs": {"TargetSlot": {"properties": {"question_priority": {"default": 0, "title": "過去のインタビューで何回情報を引き出したか（回数）", "type": "integer"}, "value": {"anyOf": [{"type": "string"}, {"type": "null"}], "default": null, "title": "スロットの値"}}, "title": "TargetSlot", "type": "object"}}, "properties": {"Target_Slot": {"additionalProperties": {"$ref": "#/$defs/TargetSlot"}, "title": "スロット", "type": "object"}, "Question": {"title": "質問", "type": "string"}}, "required": ["Target_Slot", "Question"]}
